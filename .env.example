# Copy this file to `.env` and fill in real values for local development.
# `.env` is gitignored — never commit real keys.

# LLM backend that generates answers: "ollama" (default, local) or "gemini" (hosted).
LLM_BACKEND=ollama

# Required only when LLM_BACKEND=gemini. Get a free key from https://aistudio.google.com/apikey
# The server reads this from the environment; it is never sent to the browser.
# GEMINI_API_KEY=your-key-here

# Optional: override the Gemini model (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash
